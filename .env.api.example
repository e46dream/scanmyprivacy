# ScanMyPrivacy Environment Variables

# ==========================================
# 1. BROWSERLESS (Optional - for free tier)
# ==========================================
BROWSERLESS_TOKEN=your_browserless_token_here

# Get free token at: https://browserless.io (1000 units/month free)
# Without this, falls back to local Chromium

# ==========================================
# 2. SUPABASE (Required)
# ==========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Get these at: https://supabase.com
# Use SERVICE KEY (not anon key) for server operations

# ==========================================
# 3. STRIPE (Required)
# ==========================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Get keys at: https://stripe.com
# Use TEST keys for development
# Get webhook secret by running: stripe listen --forward-to localhost:3000/webhook/stripe

# ==========================================
# 4. PAYPAL (Optional - for PayPal payments)
# ==========================================
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_ENV=sandbox

# Get keys at: https://developer.paypal.com
# Use sandbox for testing, set PAYPAL_ENV=live for production
# Webhook endpoint: /webhook/paypal

# ==========================================
# 5. RAZORPAY / UPI (Optional - for India payments)
# ==========================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Get keys at: https://razorpay.com (India only)
# Supports UPI, Cards, NetBanking
# Webhook endpoint: /webhook/razorpay

# ==========================================
# 6. PDFBOLT (Required for PDF generation)
# ==========================================
PDFBOLT_API_KEY=your_pdfbolt_key
PDFBOLT_TEMPLATE_ID=your_template_id

# Get at: https://pdfbolt.com
# Create template using their visual editor with Handlebars variables

# ==========================================
# 7. RESEND (Required for email)
# ==========================================
RESEND_API_KEY=re_xxxxxxxx

# Get free key at: https://resend.com
# 3000 emails/day free for dev domains

# ==========================================
# 8. OPTIONAL: Production domain
# ==========================================
NEXT_PUBLIC_URL=https://scanmyprivacy.com
