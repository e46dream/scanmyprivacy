{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_22", "chromium"]
        },
        "build": {
          "cmds": ["npm ci", "npx playwright install chromium", "npx playwright install-deps chromium"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "node api/server-simple.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
